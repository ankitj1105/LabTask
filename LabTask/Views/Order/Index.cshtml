@model IEnumerable<LabTask.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="text-center mb-5">
    <h1 class="display-4">Order System</h1>
    <p class="text-muted">A simple overview of all active and past orders.</p>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0 bg-white">
        <thead class="bg-light">
            <tr>
                <th>Order ID</th>
                <th>Type</th>
                <th>Date</th>
                <th>Status</th>
                <th class="text-end">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td><strong>#@order.Id</strong></td>
                    <td><span class="badge bg-secondary">@order.GetType().Name.Replace("Order", "")</span></td>
                    <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                    <td>
                        @{
                            var badgeClass = order.Status switch
                            {
                                "Delivered" => "bg-success",
                                "Processing" => "bg-warning text-dark",
                                "New" => "bg-primary",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@order.Status</span>
                    </td>
                    <td class="text-end fw-bold">@order.CalculateTotal().ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
